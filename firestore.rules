rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - each user can only read/write their own data
    match /users/{userId} {
      // User can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // User can create their own document during registration
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'nama', 'email', 'profileImage', 'kelasAktif', 'topikProgress'])
        && request.resource.data.uid == userId;
      
      // User can update their own document (progress, kelasAktif, profileImage)
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['topikProgress', 'kelasAktif', 'profileImage']);
      
      // No deletion allowed
      allow delete: if false;

      // Validate topikProgress sub-fields
      match /topikProgress/{topicKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
